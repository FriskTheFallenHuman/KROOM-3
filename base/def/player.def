/***********************************************************************
 player
***********************************************************************/

/***********************************************************************
 single player model
***********************************************************************/

model model_sp_marine {
	inherit								model_player_base_anims
	skin								skins/characters/player/greenmarine.skin

	offset								( 0 0 1 )

	mesh								models/md5/characters/npcs/playermoves/spplayer.md5mesh

	channel torso						( *Waist )
	channel legs						( *origin -*Waist SPINNER eyecontrol)
}

/***********************************************************************
 player_doommarine

 single player model
***********************************************************************/

entityDef player_doommarine {
	"inherit"							"player_id_base"

	"pda_name"							"personal"
	"player_expansion"					"d3"

	"hud"								"guis/hud.gui"
	"mphud"								"guis/mphud.gui"
	"cursor"							"guis/cursor.gui"

	"model"								"model_sp_marine"
	"def_head"							"head_player"

	"head_joint"						"Shoulders"

	"copy_joint neckcontrol"			"neckcontrol"
	"copy_joint headcontrol"			"headcontrol"
	"copy_joint_world eyecontrol"		"eyecontrol"
}
